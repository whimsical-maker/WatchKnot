generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth schema
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  isAdmin       Boolean   @default(false)
  isBanned      Boolean   @default(false)
  accounts      Account[]
  sessions      Session[]

  // App specific
  movies        Movie[]
  tickets       Ticket[]
  posts         Post[]
  comments      Comment[]
  reactions     Reaction[]
  blocksInitiated Block[] @relation("Blocker")
  blocksReceived  Block[] @relation("Blocked")
  friendshipsInitiated Friendship[] @relation("UserFriendshipsInitiated")
  friendshipsReceived  Friendship[] @relation("UserFriendshipsReceived")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// WatchKnot Specific Models

model Movie {
  id           String   @id @default(cuid())
  title        String
  year         Int?
  genre        String?
  posterUrl    String?
  rating       Float?
  description  String?
  mediaType    String?  // Movie, TV Show, Web Series, Anime
  seasons      Int?     // For TV shows
  videoUrl     String?  // For the embedded media player
  languageNote String?  // Hindi Dubbed, Bengali Subs, etc.
  addedById    String
  addedBy      User     @relation(fields: [addedById], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  tickets      Ticket[]
  posts        Post[]
  seasonList   Season[]
}

model Season {
  id           String   @id @default(cuid())
  movieId      String
  seasonNumber Int
  title        String?
  createdAt    DateTime @default(now())

  movie        Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  episodes     Episode[]

  @@unique([movieId, seasonNumber])
}

model Episode {
  id           String   @id @default(cuid())
  seasonId     String
  episodeNumber Int
  title        String?
  videoUrl     String
  duration     Int?     // in minutes
  createdAt    DateTime @default(now())

  season       Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, episodeNumber])
}

model Ticket {
  id           String   @id @default(cuid())
  movieId      String
  userId       String
  message      String?
  seatRow      String?
  seatNumber   Int?
  createdAt    DateTime @default(now())

  movie        Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([movieId, seatRow, seatNumber])
}

model Friendship {
  id        String   @id @default(cuid())
  user1Id   String
  user2Id   String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  user1     User     @relation("UserFriendshipsInitiated", fields: [user1Id], references: [id], onDelete: Cascade)
  user2     User     @relation("UserFriendshipsReceived", fields: [user2Id], references: [id], onDelete: Cascade)

  @@unique([user1Id, user2Id])
}

model Post {
  id        String   @id @default(cuid())
  userId    String
  content   String
  ticketId  String?
  mediaUrl  String?  // Image or short video url
  mediaType String?  // 'image' or 'video'
  movieId   String?
  privacy   String   @default("FRIENDS") // "ME", "FRIENDS", "PUBLIC"
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie?   @relation(fields: [movieId], references: [id], onDelete: SetNull)
  comments  Comment[]
  reactions Reaction[]
}

model Reaction {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  type      String   // e.g., 'wow', 'care', 'like'

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
